# Firebase client (public — safe for the browser)
# Copy to .env.local and fill in from Firebase Console → Project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Twilio Verify (server-only — NEVER prefix with NEXT_PUBLIC_)
# From Twilio Console → Account Info + Verify → Services
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Firebase Admin SDK (server-only — NEVER prefix with NEXT_PUBLIC_)
# Paste the full service-account JSON as a single-line string.
# Tip: jq -c . serviceAccount.json
# Private-key newlines can stay as \n inside the JSON string.
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=

# Sentry error monitoring
# DSNs are public identifiers and are safe to expose to the browser.
NEXT_PUBLIC_SENTRY_DSN=

# Optional build-time source map upload (SENTRY_AUTH_TOKEN is server-only).
# Generate the source-map upload token from your Sentry project setup.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
