rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isWeddingMember(weddingId) {
      return isSignedIn()
        && weddingId != null
        && request.auth.uid in get(/databases/$(database)/documents/weddings/$(weddingId)).data.memberUids;
    }

    function isVendorOwner(vendorId) {
      return isSignedIn()
        && vendorId != null
        && get(/databases/$(database)/documents/vendors/$(vendorId)).data.ownerUid == request.auth.uid;
    }

    // Client-side verification-error log. These are written during phone auth,
    // often BEFORE the user is signed in, so create can't require auth. Abuse is
    // limited by strict shape + size validation, and the log is never readable
    // or editable from a client (inspect it via the Firebase Console/Admin SDK).
    function isValidVerificationError() {
      let d = request.resource.data;
      return d.keys().hasOnly(['flow', 'stage', 'code', 'message', 'rawCode', 'rawMessage', 'phone', 'uid', 'timestamp'])
        && d.flow is string && d.flow.size() <= 40
        && d.stage is string && d.stage.size() <= 20
        && d.code is string && d.code.size() <= 100
        && d.message is string && d.message.size() <= 500
        && (!d.keys().hasAny(['rawCode']) || (d.rawCode is string && d.rawCode.size() <= 100))
        && (!d.keys().hasAny(['rawMessage']) || (d.rawMessage is string && d.rawMessage.size() <= 500))
        && d.phone is string && d.phone.size() <= 40
        && d.uid is string && d.uid.size() <= 128
        && d.timestamp is number;
    }

    // Written when signInWithPhoneNumber genuinely resolves with a verificationId.
    // Same pre-auth create policy as verification_errors — client cannot read.
    function isValidVerificationSuccess() {
      let d = request.resource.data;
      return d.keys().hasOnly(['flow', 'phone', 'verificationId', 'hasVerificationId', 'uid', 'timestamp'])
        && d.flow is string && d.flow.size() <= 40
        && d.phone is string && d.phone.size() <= 40
        && d.verificationId is string && d.verificationId.size() > 0 && d.verificationId.size() <= 24
        && d.hasVerificationId is bool && d.hasVerificationId == true
        && d.uid is string && d.uid.size() <= 128
        && d.timestamp is number;
    }

    function guestRsvpOnlyUpdate() {
      let allowed = ['rsvp', 'rsvpSource', 'updatedAt'];
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(allowed)
        || changed.hasOnly(['rsvp', 'updatedAt'])
        || changed.hasOnly(['rsvpSource', 'updatedAt']);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /weddings/{weddingId} {
      allow read: if isWeddingMember(weddingId);
      allow create: if isSignedIn();
      allow update, delete: if isWeddingMember(weddingId);
    }

    match /guests/{inviteToken} {
      allow get: if true;
      allow list: if isSignedIn()
        && isWeddingMember(resource.data.weddingId);
      allow create, delete: if isSignedIn()
        && isWeddingMember(request.resource.data.weddingId);
      allow update: if isWeddingMember(resource.data.weddingId)
        || guestRsvpOnlyUpdate();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn()
        && isWeddingMember(resource.data.weddingId);
      allow create: if isSignedIn()
        && isWeddingMember(request.resource.data.weddingId);
      allow update, delete: if isSignedIn()
        && isWeddingMember(resource.data.weddingId);
    }

    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isVendorOwner(vendorId);
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        isWeddingMember(resource.data.weddingId)
        || isVendorOwner(resource.data.vendorId)
      );
      allow create: if isSignedIn()
        && isWeddingMember(request.resource.data.weddingId);
      allow update: if isSignedIn() && (
        isWeddingMember(resource.data.weddingId)
        || isVendorOwner(resource.data.vendorId)
      );
      allow delete: if isWeddingMember(resource.data.weddingId);
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        isWeddingMember(get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.weddingId)
        || isVendorOwner(get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.vendorId)
      );
      allow create: if isSignedIn()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && (
          isWeddingMember(get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.weddingId)
          || isVendorOwner(get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.vendorId)
        );
      allow update, delete: if false;
    }

    match /typing/{bookingId} {
      allow read, write: if isSignedIn();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn()
        && isWeddingMember(request.resource.data.weddingId);
    }

    match /verification_errors/{errorId} {
      allow create: if isValidVerificationError();
      allow read, update, delete: if false;
    }

    match /verification_success/{successId} {
      allow create: if isValidVerificationSuccess();
      allow read, update, delete: if false;
    }
  }
}
